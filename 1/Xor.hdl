// File name: projects/1/Xor.hdl
/**
 * Exclusive-or gate:
 * if ((a and Not(b)) or (Not(a) and b)) out = 1, else out = 0
 */
CHIP Xor {
    IN a, b;
    OUT out;

    PARTS:
    	Not(in=a, out=anot);
	Not(in=b, out=bnot);
	And(a=anot, b=b, out=out1);
	And(a=a, b=bnot, out=out2);
	Or(a=out1, b=out2, out=out);
}