// File name: projects/1/Mux.hdl
/** 
 * Multiplexor:
 * if (sel = 0) out = a, else out = b
 */
CHIP Mux {
    IN a, b, sel;
    OUT out;

    PARTS:
    And(a=b, b=sel, out=bs);
    Not(in=sel, out=sn);
    And(a=a, b=sn, out=asn);
    Or(a=bs, b=asn, out=out);
}